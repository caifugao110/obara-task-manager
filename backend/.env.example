# ======================
# Obara Task Manager 环境变量配置示例
# ======================
# 复制此文件为 .env 并根据实际情况修改
# 注意：.env 文件不应提交到版本控制系统

# ----------------------
# 服务器配置
# ----------------------
# 后端服务端口
PORT=5000

# 运行环境 (development, production)
NODE_ENV=development

# ----------------------
# JWT 认证配置
# ----------------------
# JWT 签名密钥 - 生产环境务必修改为随机字符串！
JWT_SECRET=your-secret-key-change-in-production-2026

# JWT 过期时间
JWT_EXPIRES_IN=7d

# ----------------------
# 安全配置
# ----------------------
# 登录限流配置
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=20

# ----------------------
# 数据库配置
# ----------------------
# JSON 数据库文件路径
DB_PATH=./db.json

# ----------------------
# CORS 配置 (可选)
# ----------------------
# 允许的前端地址，多个用逗号分隔
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ----------------------
# 日志配置 (可选)
# ----------------------
# 日志级别 (error, warn, info, debug)
# LOG_LEVEL=info
